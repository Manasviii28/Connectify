<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-5 text-white">
        <a class="bg-red-500" href="/login">login</a>
        <h1>SIGN UP</h1>
        <form action="/signup" method="post">
            <input class=" bg-zinc-500"  type="email" placeholder="email" name="email">
            <input class=" bg-zinc-500"  type="text" placeholder="username" name="name">
            <input class=" bg-zinc-500"  type="number" placeholder="age" name="age">
            <input class=" bg-zinc-500"  type="password" placeholder="password" name="password">
            <input class="bg-blue-500  text-black bg-zinc-500"type="submit"  value="sign up">
        </form>
    </div>
    
</body>
</html>