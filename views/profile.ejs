<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-5 text-white">
        <a class="bg-red-500" href="/logout">logout</a>
        <h1>hello,<%=user.name%></h1>
        <h3>create post</h3>
        <h5></h5>
        <form action="/profile" method="post">
            <textarea class="resize-none" placeholder="whats on your mind" name="content"></textarea>
            <input type="submit" value="post">
        </form>
        <div>
            <h3>All of your posts</h3>
            
            <div class="   ">
                <%if(user.posts.length>0){%>
                    <%user.posts.forEach(function(post){%>
                    <div class=" bg-zinc-500 w-1/3 p-3 m-3">
                        <h3>@<%= user.name%></h3>
                        <p><%=post.content%></p>
                        <div>
                            <a href="/edit/<%=post._id%>">edit</a>
                            <a>like</a>
                            <a href="/delete/<%=post._id%>">delete</a>
                        </div>
                    </div>
                    

                    <%}) %>

                <%}else {%>
                    <h3>no post yet</h3>

                <%}%>
                
            </div> 
            
        </div>
        
        
    </div>
    
</body>
</html>