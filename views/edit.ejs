<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-5 text-white">
        <a class="bg-red-500" href="/logout">logout</a>
        <h1>update post</h1>
        <form action="/update/<%=post._id%>" method="post">
            <textarea class="resize-none text-black bg-zinc-500 "   placeholder="update" name="content"   ><%=post.content%></textarea>
            <input class="bg-blue-500" type="submit" value="update">
        </form>   
    </div>
    
</body>
</html>